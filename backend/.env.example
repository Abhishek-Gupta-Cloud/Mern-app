# ──────────────────────────────────────────────────────────────────────
# MERN Backend Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and update values for your environment

# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ───────────────────────────────────────────────────────
# Local development
MONGO_URI=mongodb://localhost:27017/mernapp

# MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Docker Compose (production)
# MONGO_URI=mongodb://admin:password@mongo:27017/mernapp?authSource=admin

# ── Authentication ────────────────────────────────────────────────
# Generate JWT_SECRET with: openssl rand -base64 64
# CRITICAL: Change this to a long, random string in production!
JWT_SECRET=your-super-secret-key-change-me-in-production
JWT_EXPIRES_IN=7d

# ── Security – CORS ──────────────────────────────────────────────
# Comma-separated list of allowed origins
# Development
# CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost:3000

# Production
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Docker Compose (internal)
CORS_ORIGINS=http://localhost,http://frontend

# ── Optional: Third-party integrations ────────────────────────────
# Sentry error tracking
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# DataDog APM
# DD_TRACE_ENABLED=true
# DD_SERVICE=mern-backend
# DD_ENV=production
