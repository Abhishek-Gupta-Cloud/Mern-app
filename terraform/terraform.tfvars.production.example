# ===================================================================
# PRODUCTION CONFIGURATION with HA/DR
# ===================================================================
# Multi-region failover + read replicas
# Cost: ~$700/month
# ===================================================================

# Project Configuration
project_name = "mern-app"
environment  = "production"

# AWS Regions
primary_region   = "us-east-1"
secondary_region = "us-west-2"

# VPC Configuration
primary_vpc_cidr   = "10.0.0.0/16"
secondary_vpc_cidr = "10.1.0.0/16"

# Kubernetes Configuration
kubernetes_version = "1.30"
instance_types     = ["t3.medium", "t3.large"]

# Primary Region EKS Nodes
primary_node_group_desired = 3
primary_node_group_min     = 3
primary_node_group_max     = 10

# Secondary Region EKS Nodes
secondary_node_group_desired = 2
secondary_node_group_min     = 2
secondary_node_group_max     = 5

# Database Configuration - DocumentDB
# DocumentDB is used for the MongoDB-compatible backend in production.
documentdb_database_name           = "mernapp"
documentdb_username                = "admin"
documentdb_engine_version          = "5.0.0"
documentdb_instance_class          = "db.r5.large"
documentdb_instance_count          = 2
documentdb_backup_retention_period = 7
documentdb_preferred_backup_window = "03:00-04:00"
documentdb_preferred_maintenance_window = "sun:04:00-sun:05:00"
documentdb_parameter_group_family = "docdb5.0"

# Features
enable_monitoring  = true
enable_autoscaling = true
enable_ingress     = true

# Domain & DNS
domain_name = "yourdomain.com"

# Monitoring
alarm_email = "devops@yourdomain.com"
enable_kubernetes_monitoring = true
monitoring_storage_class_name = "gp3"
grafana_persistence_size = "20Gi"
prometheus_persistence_size = "50Gi"
alertmanager_persistence_size = "20Gi"

# Tags
tags = {
  Owner       = "DevOps"
  CostCenter  = "Engineering"
  Compliance  = "SOC2"
  Application = "MERN"
  DataTier    = "Sensitive"
  Environment = "Production"
}
