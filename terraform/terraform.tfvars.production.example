# ===================================================================
# PRODUCTION CONFIGURATION with HA/DR
# ===================================================================
# Multi-region failover + read replicas
# Cost: ~$700/month
# ===================================================================

# Project Configuration
project_name = "mern-app"
environment  = "production"

# AWS Regions
primary_region   = "us-east-1"
secondary_region = "us-west-2"

# VPC Configuration
primary_vpc_cidr   = "10.0.0.0/16"
secondary_vpc_cidr = "10.1.0.0/16"

# Kubernetes Configuration
kubernetes_version = "1.30"
instance_types     = ["t3.medium", "t3.large"]

# Primary Region EKS Nodes
primary_node_group_desired = 3
primary_node_group_min     = 3
primary_node_group_max     = 10

# Secondary Region EKS Nodes
secondary_node_group_desired = 2
secondary_node_group_min     = 2
secondary_node_group_max     = 5

# Database Configuration - Multi-AZ + Read Replica
db_name               = "merndb"
db_engine             = "mongodb"
db_engine_version     = "7.0"
db_instance_class     = "db.t3.medium"
db_allocated_storage  = 100
db_multi_az           = true

# Features
enable_monitoring  = true
enable_autoscaling = true
enable_ingress     = true

# Domain & DNS
domain_name = "yourdomain.com"

# Monitoring
alarm_email = "devops@yourdomain.com"

# Tags
tags = {
  Owner       = "DevOps"
  CostCenter  = "Engineering"
  Compliance  = "SOC2"
  Application = "MERN"
  DataTier    = "Sensitive"
  Environment = "Production"
}
