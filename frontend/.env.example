VITE_API_URL=/api
# Optionally set the full gateway URL in production
# VITE_API_URL=https://api.yourdomain.com/api
# ── Frontend Environment Variables ──
# Copy to .env.local and fill in values

# API URL – points to backend
# For local development: http://localhost:5000
# For production: use relative path /api (proxied by nginx)
VITE_API_URL=/api

# Optional: Sentry or error tracking
# VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/project

# Optional: Analytics
# VITE_ANALYTICS_ID=your-tracking-id
